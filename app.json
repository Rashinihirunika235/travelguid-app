{
  "expo": {
    "name": "TravelGuideApp",
    "slug": "TravelGuideApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/image/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "travel-guide-app",
    "splash": {
      "image": "./assets/image/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rashini.travelguide"
    },
    "android": {
      "package": "com.rashini.travelguide",
      "adaptiveIcon": {
        "foregroundImage": "./assets/image/background.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "favicon": "./assets/image/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f7a5401d-e03e-4ab5-9184-c2d8e11b008e"
      }
    }
  }
}
